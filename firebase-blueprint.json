{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "An affiliate product listing",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string", "description": "Legacy single image URL" },
        "imageUrls": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "List of image URLs or base64 strings for slideshow"
        },
        "affiliateLink": { "type": "string" },
        "price": { "type": "string" }
      },
      "required": ["title", "description", "category", "affiliateLink"]
    },
    "Coupon": {
      "title": "Coupon",
      "description": "A discount code or deal",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "code": { "type": "string" },
        "link": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["title", "code", "link", "description"]
    },
    "SiteSettings": {
      "title": "SiteSettings",
      "description": "Global settings for the site",
      "type": "object",
      "properties": {
        "aboutText": { "type": "string" },
        "contactWhatsApp": { "type": "string" },
        "privacyText": { "type": "string" }
      },
      "required": ["aboutText", "contactWhatsApp", "privacyText"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Collection of affiliate products"
    },
    "/coupons/{couponId}": {
      "schema": { "$ref": "#/entities/Coupon" },
      "description": "Collection of discount codes and deals"
    },
    "/settings/{settingId}": {
      "schema": { "$ref": "#/entities/SiteSettings" },
      "description": "Global site settings (e.g., settingId = 'site')"
    }
  }
}
