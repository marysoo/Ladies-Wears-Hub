rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required)
    //   - description: string (required)
    //   - category: string (required)
    //   - imageUrl: string (required)
    //   - affiliateLink: string (required)
    //   - price: string (optional)
    //
    // Collection: coupons
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required)
    //   - code: string (required)
    //   - link: string (required)
    //   - description: string (required)
    //
    // Collection: settings
    // Document ID: 'site'
    // Fields:
    //   - aboutText: string (required)
    //   - contactWhatsApp: string (required)
    //   - privacyText: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email.lower() == "tersooaker@gmail.com");
    }

    function hasOnlyAllowedFields(allowedFields) {
      return request.resource.data.keys().hasOnly(allowedFields);
    }

    function hasRequiredFields(requiredFields) {
      return request.resource.data.keys().hasAll(requiredFields);
    }

    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string && 
             request.resource.data[field].size() >= minLen && 
             request.resource.data[field].size() <= maxLen;
    }

    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) || 
             (request.resource.data[field] is string && 
              request.resource.data[field].size() >= 0 && 
              request.resource.data[field].size() <= maxLen);
    }

    function isValidUrl(urlField) {
      return request.resource.data[urlField] is string && 
             (request.resource.data[urlField].matches("^https://.*") || request.resource.data[urlField].matches("^http://.*")) &&
             request.resource.data[urlField].size() <= 2000;
    }

    function isValidImageSource(source) {
      return source is string && 
             (source.matches("^https://.*") || 
              source.matches("^http://.*") || 
              source.size() > 100) && // Assume it's a data URL if it's long and not http
             source.size() <= 800000; // Max 800KB per image string
    }

    function isValidImageList(field) {
      return !(field in request.resource.data) || (
        request.resource.data[field] is list &&
        request.resource.data[field].size() <= 6 && // Max 6 images
        request.resource.data[field].all(img, isValidImageSource(img))
      );
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidProduct() {
      let allowedFields = ['title', 'description', 'category', 'imageUrl', 'imageUrls', 'affiliateLink', 'price', 'updatedAt', 'createdAt'];
      let requiredFields = ['title', 'description', 'category', 'affiliateLink'];
      
      return hasOnlyAllowedFields(allowedFields) &&
             hasRequiredFields(requiredFields) &&
             isValidString('title', 1, 500) &&
             isValidString('description', 1, 5000) &&
             isValidString('category', 1, 100) &&
             isValidOptionalString('imageUrl', 1, 2000) &&
             isValidImageList('imageUrls') &&
             isValidUrl('affiliateLink') &&
             isValidOptionalString('price', 1, 100) &&
             isValidOptionalString('updatedAt', 1, 100) &&
             isValidOptionalString('createdAt', 1, 100);
    }

    function isValidCoupon() {
      let allowedFields = ['title', 'code', 'link', 'description'];
      let requiredFields = ['title', 'code', 'link', 'description'];
      
      return hasOnlyAllowedFields(allowedFields) &&
             hasRequiredFields(requiredFields) &&
             isValidString('title', 1, 200) &&
             isValidString('code', 1, 50) &&
             isValidUrl('link') &&
             isValidString('description', 1, 1000);
    }

    function isValidSiteSettings() {
      let allowedFields = ['aboutText', 'contactWhatsApp', 'privacyText'];
      let requiredFields = ['aboutText', 'contactWhatsApp', 'privacyText'];
      
      return hasOnlyAllowedFields(allowedFields) &&
             hasRequiredFields(requiredFields) &&
             isValidString('aboutText', 0, 5000) &&
             isValidString('contactWhatsApp', 0, 50) &&
             isValidString('privacyText', 0, 5000);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /products/{productId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /coupons/{couponId} {
      allow read: if true; // Publicly readable
      allow create: if isAdmin() && isValidCoupon();
      allow update: if isAdmin() && isValidCoupon();
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true; // Publicly readable
      allow create: if isAdmin() && isValidSiteSettings();
      allow update: if isAdmin() && isValidSiteSettings();
      allow delete: if isAdmin();
    }
  }
}
